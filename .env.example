# Database source: "supabase" or "sqlite"
DB_SOURCE=supabase

# Supabase (required when DB_SOURCE=supabase)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# SQLite (optional, only when DB_SOURCE=sqlite)
# SQLITE_DB_PATH=./data/eyemix.sqlite

GEMINI_API_KEY=your_gemini_api_key_from_aistudio_google_com
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
CLIENT_PAYWALL_PASSWORD=iloveaiimages
PORT=3000
NODE_ENV=development
