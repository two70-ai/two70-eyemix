{
  "name": "two70-eyemix",
  "version": "1.0.0",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "postinstall": "cd client && npm install",
    "test": "jest --testPathPatterns \"server/db/\" \"server/middleware/\" \"server/routes/__tests__/\" \"server/services/__tests__/\"",
    "test:watch": "jest --testPathPatterns \"server/db/\" \"server/middleware/\" \"server/routes/__tests__/\" \"server/services/__tests__/\" --watch"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemon": "^3.0.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
